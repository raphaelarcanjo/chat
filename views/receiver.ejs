<%- contentFor('title') %>
Receiver

<%- contentFor('content') %>
<div v-bind:class="{'d-none':hide}" id="app" class="p-5">
  <p class="h5">{{caller}}</p>
  <ul v-for="message in messages">
    <li>{{message}}</li>
  </ul>
  <div class="btn-group" id="messager">
    <input type="text" name="message" id="message" class="form-control">
    <button v-on:click="sendMsg" type="button" class="btn btn-primary input-group-prepend">Send</button>
  </div>
</div>

<div id="calls" class="p-5">
  <ul>
    <li v-for="(call, index) in calls">
      <a v-bind:href="'/receiver/'+call._id" class="btn btn-success m-2">{{call.caller}}</a>
    </li>
  </ul>
</div>